{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["bun"],
    "paths": {
      "@bastani/atomic-workflows": ["../../packages/workflow-sdk/src/index.ts"]
    }
  },
  "include": [
    "**/claude/**/*.ts",
    "**/copilot/**/*.ts",
    "**/opencode/**/*.ts",
    "**/helpers/**/*.ts"
  ]
}
