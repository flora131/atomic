{
  "name": "Atomic + Claude Code (sandboxed)",
  "build": {
    "dockerfile": "../Dockerfile.sandbox",
    "context": "..",
    "args": { "AGENT_NAME": "claude" }
  },
  "overrideCommand": false,
  "features": {
    "ghcr.io/devcontainers/features/common-utils": {},
    "ghcr.io/flora131/atomic/claude:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "mounts": [
    {
      "source": "${localEnv:HOME}${localEnv:USERPROFILE}/.ssh",
      "target": "/home/vscode/.ssh",
      "type": "bind"
    },
    {
      "source": "${localEnv:HOME}${localEnv:USERPROFILE}/.gitconfig",
      "target": "/home/vscode/.gitconfig",
      "type": "bind"
    }
  ],
  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "shd101wyy.markdown-preview-enhanced",
        "Anthropic.claude-code"
      ],
      "settings": {
        "terminal.integrated.profiles.linux": {
          "nono": {
            "path": "nono",
            "args": ["shell", "--silent", "--profile", "/etc/nono/profiles/atomic-claude-code.json", "--allow-cwd"],
            "overrideName": true
          }
        },
        "terminal.integrated.defaultProfile.linux": "nono"
      }
    }
  }
}
