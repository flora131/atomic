{
  "meta": {
    "name": "atomic-claude-code",
    "version": "1.0.0",
    "description": "Atomic CLI profile for Claude Code with SSH, gitconfig, and .atomic access"
  },
  "extends": "claude-code",
  "filesystem": {
    "allow": [
      "$HOME/.vscode-server",
      "$HOME/.vscode-server-insiders",
      "$HOME/.atomic",
      "$HOME/.local/share/atomic",
      "$TMPDIR"
    ],
    "read": [
      "$HOME/.ssh",
      "$HOME/Library/Keychains",
      "$HOME/.local/share/keyrings",
      "/mnt/c/Users",
      "/workspaces",
      "/proc",
      "/etc/profile.d",
      "/etc/zsh"
    ],
    "read_file": [
      "/etc/profile",
      "/etc/bash.bashrc",
      "/etc/passwd",
      "/etc/group",
      "/etc/gitconfig",
      "$HOME/.profile",
      "$HOME/.bashrc",
      "$HOME/.zshrc"
    ]
  },
  "policy": {
    "override_deny": [
      "$HOME/.ssh",
      "$HOME/.profile",
      "$HOME/.bashrc",
      "$HOME/.zshrc"
    ]
  },
  "network": {
    "block": false
  }
}
