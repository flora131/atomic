{
  "name": "Atomic + Copilot CLI (sandboxed)",
  "build": {
    "dockerfile": "../Dockerfile.sandbox",
    "context": "..",
    "args": { "AGENT_NAME": "copilot" }
  },
  "overrideCommand": false,
  "features": {
    "ghcr.io/devcontainers/features/common-utils": {},
    "ghcr.io/flora131/atomic/copilot:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "mounts": [
    {
      "source": "${localEnv:HOME}${localEnv:USERPROFILE}/.ssh",
      "target": "/home/vscode/.ssh",
      "type": "bind"
    },
    {
      "source": "${localEnv:HOME}${localEnv:USERPROFILE}/.gitconfig",
      "target": "/home/vscode/.gitconfig",
      "type": "bind"
    }
  ],
  "remoteEnv": {
    "GH_TOKEN": "${localEnv:GH_TOKEN}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "shd101wyy.markdown-preview-enhanced"
      ],
      "settings": {
        "terminal.integrated.profiles.linux": {
          "nono": {
            "path": "nono",
            "args": ["shell", "--silent", "--profile", "/etc/nono/profiles/atomic-copilot.json", "--allow-cwd"],
            "overrideName": true
          }
        },
        "terminal.integrated.defaultProfile.linux": "nono"
      }
    }
  }
}
