{
  "meta": {
    "name": "atomic-copilot",
    "version": "1.0.0",
    "description": "Atomic CLI profile for GitHub Copilot with SSH, gitconfig, .copilot, and .atomic access"
  },
  "workdir": {
    "access": "readwrite"
  },
  "security": {
    "groups": [
      "deny_credentials",
      "deny_keychains_linux",
      "deny_keychains_macos",
      "deny_browser_data_linux",
      "deny_browser_data_macos",
      "deny_macos_private",
      "deny_shell_history",
      "deny_shell_configs",
      "dangerous_commands",
      "dangerous_commands_linux",
      "dangerous_commands_macos",
      "system_read_linux_core",
      "system_read_macos",
      "system_write_linux",
      "system_write_macos",
      "user_tools",
      "homebrew_linux",
      "homebrew_macos",
      "linux_sysfs_read",
      "vscode_linux",
      "vscode_macos",
      "node_runtime",
      "rust_runtime",
      "python_runtime",
      "nix_runtime",
      "git_config",
      "unlink_protection",
      "user_caches_linux",
      "user_caches_macos"
    ],
    "signal_mode": "isolated"
  },
  "filesystem": {
    "allow": [
      "$HOME/.vscode-server",
      "$HOME/.vscode-server-insiders",
      "$HOME/.atomic",
      "$HOME/.local/share/atomic",
      "$HOME/.copilot",
      "$TMPDIR"
    ],
    "read": [
      "$HOME/.ssh",
      "$HOME/Library/Keychains",
      "$HOME/.local/share/keyrings",
      "/mnt/c/Users",
      "/workspaces",
      "/proc",
      "/usr/local/share",
      "/usr/local/bin"
    ]
  },
  "policy": {
    "override_deny": ["$HOME/.ssh"]
  },
  "network": {
    "block": false
  }
}
