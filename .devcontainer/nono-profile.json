{
  "meta": {
    "name": "atomic-dev",
    "version": "1.0.0",
    "description": "Aggregated Atomic CLI profile for development with all agents (Claude Code, OpenCode, Copilot)"
  },
  "extends": ["claude-code", "opencode"],
  "filesystem": {
    "allow": [
      "$HOME/.vscode-server",
      "$HOME/.vscode-server-insiders",
      "$HOME/.atomic",
      "$HOME/.local/share/atomic",
      "$HOME/.copilot"
    ],
    "read": [
      "$HOME/.ssh",
      "$HOME/Library/Keychains",
      "$HOME/.local/share/keyrings",
      "/mnt/c/Users",
      "/workspaces",
      "/proc",
      "/usr/local/share",
      "/usr/local/bin"
    ]
  },
  "policy": {
    "override_deny": ["$HOME/.ssh"]
  },
  "network": {
    "block": false
  }
}
