{
  "meta": {
    "name": "atomic-opencode",
    "version": "1.0.0",
    "description": "Atomic CLI profile for OpenCode with SSH, gitconfig, and .atomic access"
  },
  "extends": "opencode",
  "filesystem": {
    "allow": [
      "$HOME/.vscode-server",
      "$HOME/.vscode-server-insiders",
      "$HOME/.atomic",
      "$HOME/.local/share/atomic"
    ],
    "read": [
      "$HOME/.ssh",
      "$HOME/Library/Keychains",
      "$HOME/.local/share/keyrings",
      "/mnt/c/Users",
      "/workspaces",
      "/proc",
      "/usr/local/share",
      "/usr/local/bin"
    ]
  },
  "policy": {
    "override_deny": ["$HOME/.ssh"]
  },
  "network": {
    "block": false
  }
}
