{
  "meta": {
    "name": "atomic-opencode",
    "version": "1.0.0",
    "description": "Atomic CLI profile for OpenCode with SSH, gitconfig, and .atomic access"
  },
  "extends": "opencode",
  "filesystem": {
    "allow": [
      "$HOME/.atomic",
      "$HOME/.local/share/atomic",
      "$HOME/.local/share/atomic/log",
      "$HOME/.local/share/atomic/telemetry-events-*.jsonl",
      "$HOME/.claude",
      "$HOME/.opencode",
      "$HOME/.copilot"
    ],
    "read": [
      "$HOME/.ssh",
      "$HOME/.gitconfig"
    ]
  },
  "policy": {
    "override_deny": ["$HOME/.ssh"]
  }
}
