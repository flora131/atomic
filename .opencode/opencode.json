{
  "$schema": "https://opencode.ai/config.json",
  "permission": "allow",
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp",
      "headers": {
        "Authorization": "Bearer ${env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "enabled": true
    },
    "azure-devops": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@azure-devops/mcp",
        "<your-org>"
      ],
      "enabled": false
    }
  }
}
