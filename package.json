{
  "name": "@bastani/atomic-workflows",
  "version": "0.0.1",
  "description": "oh-my-pi extension for multi-stage workflow authoring and execution.",
  "contributors": [
    "Norin Lavaee",
    "Alex Lavaee"
  ],
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": ">=1.3.7"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./workflows": "./workflows/index.ts",
    "./workflows/*": "./workflows/*.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flora131/atomic.git"
  },
  "homepage": "https://github.com/flora131/atomic#readme",
  "bugs": {
    "url": "https://github.com/flora131/atomic/issues"
  },
  "keywords": [
    "omp-plugin",
    "oh-my-pi",
    "omp",
    "workflow",
    "orchestration",
    "ai",
    "cli"
  ],
  "bin": {
    "atomic-workflows": "install.mjs"
  },
  "files": [
    "src/**/*.ts",
    "*.mjs",
    "workflows/**/*.ts",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "prepare": "bun scripts/install-hooks.mjs",
    "hooks:install": "prek install --prepare-hooks",
    "hooks:run": "prek run --all-files",
    "test": "bun run test:unit",
    "test:unit": "bun test test/unit",
    "test:integration": "bun test test/integration",
    "test:all": "bun run test:unit && bun run test:integration",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "omp": {
    "extensions": [
      "./src/extension/index.ts"
    ],
    "workflows": [
      "./workflows"
    ]
  },
  "peerDependencies": {
    "@oh-my-pi/pi-coding-agent": ">=14.9.5"
  },
  "devDependencies": {
    "@j178/prek": "^0.3.13",
    "@oh-my-pi/pi-coding-agent": "^14.9.5",
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3"
  }
}
