{
  "name": "@bastani/atomic",
  "version": "0.5.0-1",
  "description": "Configuration management CLI for coding agents",
  "type": "module",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flora131/atomic.git"
  },
  "keywords": [
    "cli",
    "coding-agents",
    "agents",
    "ai-engineering",
    "harness-engineering",
    "claude-code",
    "copilot-cli",
    "opencode"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "atomic": "src/cli.ts"
  },
  "files": [
    "src",
    "assets/settings.schema.json"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build --compile --no-compile-autoload-dotenv --no-compile-autoload-bunfig --outfile atomic src/cli.ts",
    "test": "bun run --cwd packages/workflow-sdk test",
    "test:coverage": "bun run --cwd packages/workflow-sdk test:coverage",
    "typecheck": "bunx tsc --noEmit",
    "lint": "oxlint --config=oxlint.json src",
    "lint:fix": "oxlint --config=oxlint.json --fix src",
    "postinstall": "lefthook install && bun run src/scripts/postinstall.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "lefthook": "^2.1.4",
    "oxlint": "^1.59.0",
    "typescript": "^6.0.2",
    "typescript-language-server": "^5.1.3"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@commander-js/extra-typings": "^14.0.0",
    "commander": "^14.0.3",
    "ignore": "^7.0.5",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
