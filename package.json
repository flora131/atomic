{
  "name": "@bastani/atomic",
  "version": "0.5.1",
  "description": "Configuration management CLI and SDK for coding agents",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flora131/atomic.git"
  },
  "keywords": [
    "cli",
    "sdk",
    "coding-agents",
    "agents",
    "ai-engineering",
    "harness-engineering",
    "claude-code",
    "copilot-cli",
    "opencode"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "atomic": "src/cli.ts"
  },
  "exports": {
    ".": "./src/sdk/index.ts",
    "./workflows": "./src/sdk/workflows/index.ts",
    "./workflows/builtin/ralph/claude": "./src/sdk/workflows/builtin/ralph/claude/index.ts",
    "./workflows/builtin/ralph/copilot": "./src/sdk/workflows/builtin/ralph/copilot/index.ts",
    "./workflows/builtin/ralph/opencode": "./src/sdk/workflows/builtin/ralph/opencode/index.ts"
  },
  "files": [
    "src",
    "tsconfig.json",
    "assets/settings.schema.json",
    ".claude/agents",
    ".opencode/agents",
    ".github/agents",
    ".github/lsp.json"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun run build.ts",
    "test": "bun test ./src ./tests",
    "test:coverage": "bun test --coverage ./src ./tests",
    "typecheck": "bunx tsc --noEmit && bunx tsc -p tests --noEmit",
    "lint": "oxlint --config=oxlint.json src",
    "lint:fix": "oxlint --config=oxlint.json --fix src",
    "prepare": "lefthook install || true"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/react": "^19.2.14",
    "lefthook": "^2.1.4",
    "oxlint": "^1.59.0",
    "typescript": "^6.0.2",
    "typescript-language-server": "^5.1.3"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.92",
    "@clack/prompts": "^1.2.0",
    "@commander-js/extra-typings": "^14.0.0",
    "@github/copilot-sdk": "^0.2.1",
    "@opencode-ai/sdk": "^1.3.17",
    "@opentui/core": "^0.1.97",
    "@opentui/react": "^0.1.97",
    "commander": "^14.0.3",
    "ignore": "^7.0.5",
    "react": "19",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
