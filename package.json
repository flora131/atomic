{
  "name": "@bastani/atomic",
  "version": "0.5.24",
  "description": "Configuration management CLI and SDK for coding agents",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flora131/atomic.git"
  },
  "keywords": [
    "cli",
    "sdk",
    "coding-agents",
    "agents",
    "ai-engineering",
    "harness-engineering",
    "claude-code",
    "copilot-cli",
    "opencode"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "atomic": "src/cli.ts"
  },
  "exports": {
    ".": {
      "bun": "./src/sdk/index.ts",
      "types": "./dist/sdk/index.d.ts"
    },
    "./workflows": {
      "bun": "./src/sdk/workflows/index.ts",
      "types": "./dist/sdk/workflows/index.d.ts"
    },
    "./*": {
      "bun": "./src/sdk/*",
      "types": "./dist/sdk/*"
    }
  },
  "files": [
    "src",
    "dist",
    "assets/settings.schema.json",
    ".agents/skills",
    ".claude/agents",
    ".claude/settings.json",
    ".opencode/agents",
    ".opencode/opencode.json",
    ".github/agents",
    ".github/lsp.json",
    ".mcp.json"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "rm -rf dist && bunx tsc --project tsconfig.build.json",
    "prepack": "bun run build",
    "test": "bun test ./src ./tests",
    "test:coverage": "bun test --coverage ./src ./tests",
    "typecheck": "bunx tsc --noEmit && bunx tsc -p tests --noEmit",
    "lint": "oxlint --config=oxlint.json src",
    "lint:fix": "oxlint --config=oxlint.json --fix src",
    "prepare": "lefthook install || true"
  },
  "trustedDependencies": [
    "lefthook"
  ],
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/react": "^19.2.14",
    "lefthook": "^2.1.6",
    "oxlint": "^1.60.0",
    "typescript": "^6.0.2",
    "typescript-language-server": "^5.1.3"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.111",
    "@clack/prompts": "^1.2.0",
    "@commander-js/extra-typings": "^14.0.0",
    "@github/copilot-sdk": "^0.2.2",
    "@opencode-ai/sdk": "^1.4.6",
    "@opentui/core": "^0.1.99",
    "@opentui/react": "^0.1.99",
    "commander": "^14.0.3",
    "ignore": "^7.0.5",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "react": "^19.2.5"
  }
}
