{
  "name": "@bastani/atomic-workflows",
  "version": "0.0.1",
  "description": "pi extension for multi-stage workflow authoring and execution.",
  "contributors": [
    "Norin Lavaee",
    "Alex Lavaee"
  ],
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": ">=1.3.14"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./workflows": "./workflows/index.ts",
    "./workflows/*": "./workflows/*.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flora131/atomic.git"
  },
  "homepage": "https://github.com/flora131/atomic#readme",
  "bugs": {
    "url": "https://github.com/flora131/atomic/issues"
  },
  "keywords": [
    "pi-plugin",
    "pi",
    "workflow",
    "orchestration",
    "ai",
    "cli"
  ],
  "files": [
    "src/**/*.ts",
    "workflows/**/*.ts",
    "skills/**/*",
    "agents/",
    "prompts/**/*",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "bun scripts/install-hooks.mjs",
    "hooks:install": "prek install --prepare-hooks",
    "hooks:run": "prek run --all-files",
    "test": "bun run test:unit",
    "test:unit": "bun test test/unit",
    "test:integration": "bun test test/integration",
    "test:all": "bun run test:unit && bun run test:integration",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "pi": {
    "extensions": [
      "./src/extension/index.ts"
    ],
    "workflows": [
      "./workflows"
    ],
    "skills": [
      "./skills"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    }
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0",
    "@j178/prek": "^0.3.13",
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3"
  }
}
