{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "pi-workflows": ["./src/index.ts"]
    }
  },
  "include": ["src/**/*", "workflows/**/*"],
  "exclude": ["node_modules", "dist", "test"]
}
