{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "lib": ["ESNext"],
    "allowImportingTsExtensions": true,
    "allowArbitraryExtensions": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@bastani/atomic-workflows": ["./src/index.ts"],
      "@oh-my-pi/pi-coding-agent": ["./src/oh-my-pi-shim.d.ts"]
    }
  },
  "include": ["src/**/*", "test/**/*", "workflows/**/*", "examples/**/*"],
  "exclude": ["node_modules"]
}
